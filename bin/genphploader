/// A script use to generate the loading file for PHP Unit

namespace Tea;

const DEBUG = false;
const KEY_HELP = 'help';
const OPTION_KEYS = [KEY_HELP];
const USAGE = "Usage: genphploader v1/compiler\n       genphploader --help";

require dirname(__DIR__) . '/compiler/__public.php';

function fail_with_error(string $message, bool $show_usage = false): void
{
	fwrite(STDERR, "\nError: {$message}\n");
	if ($show_usage) {
		fwrite(STDERR, "\n" . USAGE . "\n");
	}
	exit(1);
}

try {
	$opts = process_cli_options($argv, OPTION_KEYS);
	if (isset($opts[KEY_HELP])) {
		echo USAGE, LF;
		exit(0);
	}

	$dir = $opts[0] ?? null;
	if ($dir === null) {
		fail_with_error('Missed target dir.', true);
	}

	$realpath = realpath($dir);
	if ($realpath === false) {
		fail_with_error("Target dir '{$dir}' not found.", true);
	}

	$realpath = FileHelper::normalize_path($realpath . DS);
	$loader_file = $realpath . PUBLIC_LOADER_FILE_NAME;
	if (!file_exists($loader_file)) {
		fail_with_error(sprintf("The '%s' not found in '%s'.", PUBLIC_LOADER_FILE_NAME, $realpath));
	}

	$scanner = new PHPUnitScanner();
	$class_map = $scanner->scan($realpath);

	PHPLoaderMaker::generate_loader_file($realpath, $class_map);

	$count = count($class_map);
	echo LF, "$count classes found.", LF, LF;
	exit(0);
}
catch (Exception $e) {
	fail_with_error($e->getMessage());
}

// end
