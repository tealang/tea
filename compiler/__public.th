public func get_traces(trace_start Int = 0) #String

public class LineComment: Node, IStatement {
	public const KIND #Text
	public content String
	public construct(content String) #Void
}

public class BlockComment: Node, IStatement {
	public const KIND #Text
	public content String
	public construct(content String) #Void
}

public class DocComment: Node, IStatement {
	public const KIND #Text
	public content String
	public construct(content String) #Void
}

public class Identifiable: BaseExpression, IAssignable {
	public name String
	public symbol Symbol?
	public construct(name String) #Void
}

public class AccessingIdentifier: Identifiable {
	public const KIND #Text
	public basing BaseExpression
	public is_static Bool?
	public is_nullsafe Bool
	public construct(basing BaseExpression, name String, nullsafe Bool = false) #Void
}

public class NativeIdentifier: Identifiable {
	public const KIND #Text
}

public class PlainIdentifier: Identifiable {
	public const KIND #Text
	public ns NamespaceIdentifier?
	public generic_types Array|Dict|Null
}

public class ConstantIdentifier: PlainIdentifier {
	public const KIND #Text
	public construct(name String) #Void
}

public class VariableIdentifier: PlainIdentifier {
	public const KIND #Text
}

public class ClassKindredIdentifier: PlainIdentifier {
	public const KIND #Text
	public construct(name String) #Void
	public set_namespace(ns NamespaceIdentifier) #Void
}

public class NamespaceIdentifier: Node {
	public const KIND #Text
	public uri String
	public names Array|Dict
	public construct(names Array|Dict) #Void
	public set_names(names Array|Dict) #Void
	public is_global_space() #Bool
	public get_last_name() #Mixed
	public get_namepath() #Array|Dict
}

public class Node {
	public const KIND #Null
	public pos Int
	public leading_br Bool
	public tailing_br Bool
	public doc DocComment?
	public tailing_comment String?
	public indents String?
	public render(coder BaseCoder) String?
}

public class Operator {
	public type Int
	public tea_sign String?
	public tea_prec Int?
	public tea_assoc Int?
	public php_sign String?
	public php_prec Int?
	public php_assoc Int?
	public construct(id Int) #Void
	public is(id Int) #Bool
	public is_type(type Int) #Bool
	public get_debug_sign() #String|Int
}

public class Program: BaseDeclaration {
	public const KIND #Text
	public const SOURCE_DIALECT_UNKNOWN #Text
	public const SOURCE_DIALECT_TEA #Text
	public const SOURCE_DIALECT_PHP #Text
	public const SOURCE_DIALECT_HEADER #Text
	public parser BaseParser?
	public source_dialect String
	public as_main Bool
	public file String?
	public uses Array|Dict#List<UseStatement>
	public use_targets Array|Dict#List<UseDeclaration>
	public declarations Array|Dict#List<BaseDeclaration>
	public initializer FunctionDeclaration?
	public symbols Array|Dict#Dict<Mixed>
	public unit Unit?
	public ns NamespaceIdentifier?
	public depends_native_programs Array|Dict
	public is_native Bool
	public is_external Bool
	public construct(file String, unit Unit) #Void
	public append_declaration(decl BaseDeclaration) #Void
	public append_depends_native_program(program Program) #Void
	public count_subdirectory_levels() #UInt
}

public class Symbol {
	public name String
	public declaration BaseDeclaration
	public using UseDeclaration?
	public construct(decl BaseDeclaration) #Void
}

public class TopSymbol: Symbol {
	// no any
}

public trait ITypeTrait {
	public is_accept_type(target BaseType) #Bool
	public unite(target BaseType) BaseType
	public is_same_with(target BaseType) #Bool
	public is_same_or_based_with(target BaseType) #Bool
}

public class BaseType: Node {
	use ITypeTrait
	public const KIND #Text
	public const ACCEPT_TYPES #Array
	public name String
	public symbol Symbol?
	public is_based_with(target BaseType) #Bool
	public is_accept_single_type(target BaseType) #Bool
}

public class TypeReference: BaseType {
	public const KIND #Text
	public ns NamespaceIdentifier?
	public generic_types Array|Dict#List<BaseType>
	public construct(name String) #Void
	public set_namespace(ns NamespaceIdentifier) #Void
	public unite(target BaseType) BaseType
	public is_based_with(target BaseType) #Bool
	public is_same_or_based_with(target BaseType) #Bool
	public is_accept_single_type(target BaseType) #Bool
}

public class SingleGenericType: BaseType {
	public generic_type BaseType?
	public construct(generic_type BaseType? = null) #Void
	public unite(target BaseType) BaseType
	public is_accept_single_type(target BaseType) #Bool
	public is_same_with(target BaseType) #Bool
	public is_same_or_based_with(target BaseType) #Bool
}

public class UnionType: BaseType {
	public const KIND #Text
	public name String
	public members Array|Dict#List<BaseType>
	public construct(members Array|Dict = []) #Void
	public get_members() #List<BaseType>
	public count() #UInt
	public is_all_array_types() #Bool
	public is_same_or_based_with(target BaseType) #Bool
	public is_all_dict_types() #Bool
	public has_array_or_dict_type() #Bool
	public unite(target BaseType) BaseType
	public deunite(target BaseType) #Any
	public merge_with_single_type(target BaseType) BaseType
	public merge_with_union_type(target UnionType) BaseType
	public contains_type(target BaseType) #Bool
	public contains_single_type(target BaseType) #Bool
	public is_same_with(target BaseType) #Bool
	public is_based_with(target BaseType) #Bool
	public is_accept_single_type(target BaseType) #Bool
}

public class MetaType: SingleGenericType {
	public name String
}

public class VoidType: BaseType {
	public name String
	public is_accept_single_type(target BaseType) #Bool
}

public class NoneType: BaseType {
