}

public class Unit {
	public name String?
	public ns NamespaceIdentifier?
	public dist_ns_uri String?
	public path String
	public loader Program?
	public as_main Bool
	public is_trusted Bool
	public namespaces Array|Dict#List<NamespaceDeclaration>
	public programs Array|Dict#List<Program>
	public symbols Array|Dict|Null
	public use_units Array|Dict#List<Unit>
	public trusted_use_units Array|Dict#Dict<Bool>
	public factory ASTFactory?
	public construct(path String) #Void
	public append_program(program Program) #Void
	public get_abs_path(path String) #String
}

public class WhiteSpaceNode: Node {
	public const KIND #Text
}

public class BaseControlBlock: BaseStatement, IBlock {
	use IBlockTrait
}

public class ForBlock: BaseControlBlock, IElseAble, IExceptAble, IBreakAble, IContinueAble {
	use ElseTrait, ExceptTrait
	public const KIND #Text
	public args1 Array|Dict
	public args2 Array|Dict
	public args3 Array|Dict
	public construct(args1 Array|Dict, args2 Array|Dict, args3 Array|Dict) #Void
}

public class ForEachBlock: BaseControlBlock, IElseAble, IExceptAble, IBreakAble, IContinueAble {
	use ElseTrait, ExceptTrait
	public const KIND #Text
	public iterable BaseExpression
	public key BaseExpression?
	public val BaseExpression
	public construct(iterable BaseExpression, key BaseExpression?, val BaseExpression) #Void
}

public class ForInBlock: BaseControlBlock, IElseAble, IExceptAble, IBreakAble, IContinueAble {
	use ElseTrait, ExceptTrait
	public const KIND #Text
	public key ParameterDeclaration?
	public val ParameterDeclaration
	public iterable BaseExpression
	public construct(key ParameterDeclaration?, val ParameterDeclaration, iterable BaseExpression) #Void
}

public class ForToBlock: BaseControlBlock, IElseAble, IExceptAble, IBreakAble, IContinueAble {
	use ElseTrait, ExceptTrait
	public const KIND #Text
	public key ParameterDeclaration?
	public val ParameterDeclaration
	public start BaseExpression
	public end BaseExpression
	public step Int?
	public is_downto_mode Bool
	public construct(key ParameterDeclaration?, val ParameterDeclaration, start BaseExpression, end BaseExpression, step Int?) #Void
}

public interface IBlock {
	public add_rebound_variable(decl IVariableDeclaration) #Void
	public get_rebound_variables() Array|Dict
	public set_body_with_statements(statements Array|Dict) #Void
	public set_belong_block(block BaseDeclaration|IBlock|Null)
	public get_label() String?
	public mark_as_transfered()
	public has_transfered() Bool
	public has_symbol(name String) Bool
	public get_symbol(name String) Symbol?
	public set_symbol(name String, symbol Symbol)
	public get_symbols() Array|Dict
	public get_belong_block() BaseDeclaration|IBlock|Null
}

public trait IBlockTrait {
	public label String?
	public body #List<IStatement>|BaseExpression
	public symbols Array|Dict#Dict<Mixed>
	public belong_block BaseDeclaration|IBlock|Null
	public is_transfered Bool
	public set_body_with_statements(statements Array|Dict) #Void
	public get_label() String?
	public add_rebound_variable(decl IVariableDeclaration) #Void
	public get_rebound_variables() Array|Dict
	public mark_as_transfered()
	public has_transfered() Bool
	public has_symbol(name String) Bool
	public get_symbol(name String) Symbol?
	public set_symbol(name String, symbol Symbol)
	public get_symbols() Array|Dict
	public set_belong_block(block BaseDeclaration|IBlock|Null)
	public get_belong_block() BaseDeclaration|IBlock|Null
	public reset_rebound_types() Array|Dict
}

public interface IElseAble {
	public get_else_branches() #Void
	public set_else_block(__else IElseBlock)
}

public interface IElseBlock {
	// no any
}

public trait ElseTrait {
	public else IElseBlock?
	public get_else_branches() #Array
	public set_else_block(__else IElseBlock)
}

public class BaseIfBlock: BaseControlBlock, IElseAble, IExceptAble {
	use ElseTrait
	public condition BaseExpression
	public construct(condition BaseExpression) #Void
}

public class IfBlock: BaseIfBlock, IStatement {
	use ExceptTrait
	public const KIND #Text
}

public class ElseIfBlock: BaseIfBlock, IElseBlock {
	use ExceptTrait
	public const KIND #Text
}

public class ElseBlock: BaseControlBlock, IElseBlock {
	public const KIND #Text
}

public class MatchBlock: BaseExpression, IBlock {
	use IBlockTrait
	public const KIND #Text
	public subject BaseExpression
	public arms Array|Dict#List<MatchArm>
	public value_type BaseType?
	public construct(subject BaseExpression) #Void
	public set_arms(arms Array|Dict) #Void
}

public class MatchArm: BaseExpression {
	public const KIND #Text
	public patterns Array|Dict#List<BaseExpression>
	public return BaseExpression
	public construct(patterns Array|Dict) #Void
}

public class SwitchBlock: BaseControlBlock, IElseAble, IExceptAble, IBreakAble {
	use ElseTrait, ExceptTrait
	public const KIND #Text
	public subject BaseExpression
	public branches Array|Dict#List<SwitchBranch>
	public construct(subject BaseExpression) #Void
	public set_branches(branches Array|Dict) #Void
}

public class SwitchBranch: BaseControlBlock {
	public const KIND #Text
	public patterns Array|Dict#List<BaseExpression>
	public construct(patterns Array|Dict) #Void
}

public interface IExceptAble {
	public add_catching_block(block CatchBlock)
	public set_finally_block(block FinallyBlock)
}

public interface IExceptBlock {
	// no any
}

public class TryBlock: BaseControlBlock, IExceptAble {
	use ExceptTrait
	public const KIND #Text
}

public class CatchBlock: BaseControlBlock {
	public const KIND #Text
	public var VariableDeclaration?
	public declared_type BaseType?
	public construct(__var VariableDeclaration?, declared_type BaseType? = null) #Void
}

public class FinallyBlock: BaseControlBlock {
	public const KIND #Text
}

public trait ExceptTrait {
	public catchings Array|Dict#List<CatchBlock>
	public finally FinallyBlock?
	public has_exceptional() #Bool
	public add_catching_block(block CatchBlock)
	public set_finally_block(block FinallyBlock)
}

public class WhileLikeBlock: BaseControlBlock, IExceptAble, IBreakAble, IContinueAble {
	use ElseTrait, ExceptTrait
	public condition BaseExpression
	public set_else_block(__else IElseBlock) #Void
}

public class WhileBlock: WhileLikeBlock {
	public const KIND #Text
	public construct(condition BaseExpression) #Void
}

public class DoWhileBlock: WhileLikeBlock {
	public const KIND #Text
}

public class LoopBlock: BaseControlBlock, IExceptAble, IBreakAble, IContinueAble {
	use ExceptTrait
	public const KIND #Text
}

public interface IDeclaration {
	public get_name() String?
}

public interface ICallableDeclaration {
	// no any
}

public interface IValuableDeclaration {
	public get_expressed_type() BaseType
}

public interface IUnknownIdentifierContainer {
	public append_unknow_identifier(identifier PlainIdentifier|TypeReference) #Void
	public remove_unknow_identifier(identifier PlainIdentifier|TypeReference) #Void
}

public trait TypingTrait {
	public is_virtual Bool
	public declared_type BaseType?
	public noted_type BaseType?
	public noted_type_source String?
	public noted_type_from_phpdoc Bool
	public noted_type_nullable_inherited Bool
	public infered_type BaseType?
	public get_hinted_type() BaseType
	public get_expressed_type() BaseType
	public get_bound_type() BaseType
	public bind_type(type BaseType) #Void
}

public trait BaseDeclarationTrait {
	use TypingTrait
	public modifier String?
	public name String
	public origin_name String?
	public is_extern Bool
	public is_unit_level Bool
	public uses Array|Dict#List<UseDeclaration>
	public attributes Array|Dict#List<MetaAttribute>
	public unknow_identifiers Array|Dict#List<PlainIdentifier|TypeReference>
	public belong_block BaseDeclaration|IBlock|Null
	public program Program?
	public get_name() String?
	public set_depends_to_unit_level() #Void
	public append_use_declaration(use UseDeclaration) #Void
	public append_unknow_identifier(identifier PlainIdentifier|TypeReference) #Void
	public remove_unknow_identifier(identifier PlainIdentifier|TypeReference) #Void
	public append_unknow_identifiers_from_declaration(decl BaseDeclaration) #Void
}

public class BaseDeclaration: Node, IDeclaration, IUnknownIdentifierContainer {
	use BaseDeclarationTrait
}

public class RootDeclaration: BaseDeclaration, IStatement {
	public ns NamespaceIdentifier?
	public program Program?
	public set_namespace(ns NamespaceIdentifier) #Void
	public is_root_namespace() #Bool
}

public class ClassFeature {
	case ITERATOR = 0x1
	case ARRAY_ACCESS = 0x2
	case DYNAMIC_PROPERTIES = 0x4
	case MAGIC_GET = 0x100
	case MAGIC_SET = 0x200
	case MAGIC_ISSET = 0x400
	case MAGIC_UNSET = 0x800
	case MAGIC_CALL = 0x1000
	case MAGIC_CALL_STATIC = 0x2000
	public value Int
}

public class ClassKindredDeclaration: RootDeclaration {
	public extends Array|Dict#List<ClassKindredIdentifier>
	public implements Array|Dict#List<ClassKindredIdentifier>
	public usings Array|Dict#List<TraitsUsingStatement>
	public members Array|Dict#List<IClassMemberDeclaration>
	public symbols Array|Dict#Dict<Mixed>
	public belong_block BaseDeclaration|IBlock|Null
	public typing_identifier TypeReference?
	public this_class_symbol Symbol?
	public this_object_symbol Symbol?
	public define_mode Int?
