public class Exception: \Exception {
	public code #UInt
}

public class ErrorException: \ErrorException {
	public code #UInt
}

public class LogicException: \LogicException {
	public code #UInt
}

public func array_key_last(items Array|Dict) #Mixed

public func halt(msg String) #Void

public func error(msg String) #Void

