#[BuiltinFeature(Iterator)]
extern interface Iterator: Traversable {
	current() Mixed
	key() Mixed
	next() #Void
	rewind() #Void
	valid() Bool
}

extern interface IteratorAggregate: Traversable {
	getIterator() Traversable
}

extern interface SeekableIterator: Iterator {
	seek(offset Int) #Void
}

extern interface RecursiveIterator: Iterator {
	hasChildren() Bool
	getChildren() RecursiveIterator
}

extern interface Countable {
	count() Int
}

#[BuiltinFeature(ArrayAccess)]
extern interface ArrayAccess {
	offsetExists(offset Mixed) Bool
	offsetGet(offset Mixed) Mixed
	offsetSet(offset Mixed, value Mixed) #Void
	offsetUnset(offset Mixed) #Void
}

