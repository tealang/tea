public func _regex_test(regex Regex, subject String) Bool

public func _regex_capture(regex Regex, subject String) List<String>?

public func _regex_capture_all(regex Regex, subject String) List<List<String>>?

public type Regex {
	test(string String) #Bool => _regex_test(this, string)

	separate(string String) #List<String> => preg_split(this, string)

	capture(string String) #List<String>? => _regex_capture(this, string)

	capture_all(string String) #List<List<String>>? => _regex_capture_all(this, string)
}

