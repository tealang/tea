public func _std_split(it String, separator String) #List<String>

public func _std_replace(it String, search, replacement) #String

public type Bytes {
	length #UInt => strlen(this)

	find(str String, offset Int = #default) #UInt|Bool => strpos(this, str, offset)

	find_last(str String, offset Int = #default) #UInt|Bool => strrpos(this, str, offset)

	copy(start Int, length UInt = #default) #String => substr(this, start, length)
}

public type String {
	length #UInt => mb_strlen(this)

	find(str String, offset Int = #default) #UInt|Bool => mb_strpos(this, str, offset)

	find_last(str String, offset Int = #default) #UInt|Bool => mb_strrpos(this, str, offset)

	copy(start Int, length UInt = #default) #String => mb_substr(this, start, length)

	contains(val String) #Bool => str_contains(this, val)

	lowercase() #String => mb_strtolower(this)

	uppercase() #String => mb_strtoupper(this)

	split(separator String) #List<String> => _std_split(this, separator)

	replace(search, replacement) #String => _std_replace(this, search, replacement)

	trim(characters String = #default) #String => trim(this, characters)

	ltrim(characters String = #default) #String => ltrim(this, characters)

	rtrim(characters String = #default) #String => rtrim(this, characters)

	starts_with(prefix String) #Bool => str_starts_with(this, prefix)

	ends_with(suffix String) #Bool => str_ends_with(this, suffix)
}

public type Plain: String {
	// no any
}

public type Int {
	abs() UInt => int_abs(this)
}

public type UInt: Int {
	// no any
}

public type Float {
	abs() #Float => abs(this)

	ceil() #Int => ceil(this)

	floor() #Int => floor(this)

	round(precision #UInt = 0) #Float => round(this, precision)
}

public type Bool {
	// no any
}

public func _has(it Array|Dict, key String|Int|Null) #Bool

public func _vals_contains(it Array|Dict, val, strict Bool = false) #Bool

public func _array_find(it Array, val) #UInt|Bool

public func _std_array_map(it Array, callback (item) Mixed) #Array

public func _std_join(it Array|Dict, separator String) #String

public type Array {
	length UInt => count(this)

	has(key Int) #Bool => _has(this, key)

	contains(val) #Bool => _vals_contains(this, val)

	find(val) #UInt|Bool => _array_find(this, val)

	join(separator String = LF) #String => _std_join(this, separator)

	copy(start Int, length UInt = #default) #Array => array_slice(this, start, length)

	reversed() #Array => array_reverse(this)

	unshift(item) #UInt => array_unshift(this, item)

	shift() #Mixed => array_shift(this)

	push(item) #UInt => array_push(this, item)

	pop() #Mixed => array_pop(this)

	map(callback (item) Mixed) #Array => _std_array_map(this, callback)

	filter(callback (item) Mixed) #Array => array_filter(this, callback)

	reduce(callback (carry, item) Mixed, initial Mixed = #default) #Mixed => array_reduce(this, callback, initial)
}

public func _dict_find(it Dict, val) #String|Int|Bool

public func _dict_get(it Dict, key String|Int) #Mixed

public type Dict {
	length #UInt => count(this)

	has(key String?) #Bool => _has(this, key)

	contains(val) #Bool => _vals_contains(this, val)

	find(val) #String|Int|Bool => _dict_find(this, val)

	join(separator String = LF) #String => _std_join(this, separator)

	get(key String|Int) #Mixed => _dict_get(this, key)

	keys() #List<String> => array_keys(this)

	values() #Array => array_values(this)

	replace(replacement Dict) #Dict => dict_replace(this, replacement)
}

