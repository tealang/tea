public _std_split(it String, separator String) {
	return explode(separator, it)
}

public _std_replace(it String, search, replacement) {
	return str_replace(search, replacement, it);
}

// processing using byte mode
public type Bytes {
	length => strlen(this)
	find(str String, offset Int = #default) => strpos(this, str, offset)
	find_last(str String, offset Int = #default) => strrpos(this, str, offset)
	copy(start Int, length UInt = #default) => substr(this, start, length)
    
}

// processing through default charset using char/rune mode
public type String {
	length => mb_strlen(this)
	find(str String, offset Int = #default) => mb_strpos(this, str, offset)
	find_last(str String, offset Int = #default) => mb_strrpos(this, str, offset)
	copy(start Int, length UInt = #default) => mb_substr(this, start, length)
	contains(val String) => str_contains(this, val)
	lowercase() => mb_strtolower(this)
	uppercase() => mb_strtoupper(this)
	split(separator String) => _std_split(this, separator)
	replace(search, replacement) => _std_replace(this, search, replacement)

	trim(characters String = #default) => trim(this, characters)
	ltrim(characters String = #default) => ltrim(this, characters)
	rtrim(characters String = #default) => rtrim(this, characters)


    starts_with(prefix String) => str_starts_with(this, prefix)
    ends_with(suffix String) => str_ends_with(this, suffix)
}

