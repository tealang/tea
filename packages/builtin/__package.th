namespace tea\builtin

// super globals
extern var $_GET Dict
extern var $_POST Dict
extern var $_FILES Dict
extern var $_COOKIE Dict
extern var $_REQUEST Dict
extern var $_SERVER Dict
extern var $_ENV Dict

// input methods
extern const INPUT_GET Int
extern const INPUT_POST Int
extern const INPUT_COOKIE Int
extern const INPUT_ENV Int
extern const INPUT_SERVER Int

// filter types
extern const FILTER_INT Int
extern const FILTER_EMAIL Int

// the function to get value of $_GET/$_POST/$_COOKIE/$_ENV/$_SERVER
extern func filter_input(type Int, key String, filter Int = #default, options Dict = #default) String?

// range function for for-in-to loops
extern func range(start Int, end Int, step Int = 1) List<Int>

// checkers
extern func isset(expr Mixed) Bool
#[TypeAssertion(val is Bool)]
extern func is_bool(val) Bool
#[TypeAssertion(val is Float)]
extern func is_float(val) Bool
#[TypeAssertion(val is Int)]
extern func is_int(val) Bool
#[TypeAssertion(val is String)]
extern func is_string(val) Bool
#[TypeAssertion(val is Array|Dict)]
extern func is_array(val) Bool
extern func is_numeric(val) Bool

// some basic functions
extern func exit(status Int|String) Void
extern func empty(expr Mixed) Bool
extern func var_dump(expr0 Mixed, expr1 Mixed = #default, expr2 Mixed = #default, expr3 Mixed = #default)
extern func call_user_func(callable Callable, param1 Mixed = #default, param2 Mixed = #default, param3 Mixed = #default) Mixed
extern func compact(var_name0 String|Array, var_name1 String|Array = #default, var_name2 String|Array = #default, var_name3 String|Array = #default) Dict
extern func get_class(object Object = #default) String
extern func print(expr) Int
extern func print_r(expr, is_return Bool = #default)
extern func header(info String, replace = true, http_response_code Int = #default)
extern func ini_set(option String, value String|Int|Float|Bool|None) String|Bool

// dates & times
extern func time() Int
extern func date(format String, timestamp Int = #default) String
extern func gmdate(format String, timestamp Int = #default) String
extern func strtotime(datetime, now Int = #default) Int

// php builtin constants
extern const __DIR__ String
extern const __FILE__ String
extern const __LINE__ UInt
extern const __CLASS__ String
extern const __FUNCTION__ String
extern const __METHOD__ String
extern const __NAMESPACE__ String
extern const __TRAIT__ String
extern const PHP_INT_MIN Int
extern const PHP_INT_MAX UInt

// basic standard interfaces/classes
extern interface Traversable {}
#[BuiltinFeature(Iterator)]
extern interface Iterator: Traversable {
	current() Mixed
	key() Mixed
	next()
	rewind()
	valid() Bool
}
extern interface IteratorAggregate: Traversable {
	getIterator() Traversable
}
extern interface SeekableIterator: Iterator {
	seek(offset Int)
}
extern interface RecursiveIterator: Iterator {
	hasChildren() Bool
	getChildren() RecursiveIterator
}
extern interface Countable {
	count() Int
}
#[BuiltinFeature(ArrayAccess)]
extern interface ArrayAccess {
	offsetExists(offset Mixed) Bool
	offsetGet(offset Mixed) Mixed
	offsetSet(offset Mixed, value Mixed)
	offsetUnset(offset Mixed)
}
extern interface Stringable {
	public __toString() String
}
extern interface JsonSerializable {
	public jsonSerialize() Mixed
}
extern interface Serializable {
	public serialize() String
	public unserialize(data String)
}
extern interface DateTimeInterface {}
#[BuiltinFeature(DynamicProperties)]
extern class stdClass {}
extern class SplFixedArray: ArrayAccess, Countable, IteratorAggregate {}
extern class SplObjectStorage: ArrayAccess, Countable, Iterator, Serializable {}
extern class SimpleXMLElement: ArrayAccess {}
extern class PhpToken {
	public id Int
	public text String
	public line Int
	public pos Int
	public getTokenName() String?
	public is(kind Mixed) Bool
	public isIgnorable() Bool
	public __toString() String
	public static tokenize(code String, flags Int = 0) Array
}
extern class DOMDocument {}
extern class DOMNodeList {}
extern class DOMElement {}
extern class DOMAttr {}

// exceptions
extern interface Throwable: Stringable {
	public getMessage() String
	public getPrevious() Throwable?
	public getCode() Int
	public getFile() String
	public getLine() Int
	public getTrace() Array
	public getTraceAsString() String
}
extern class Exception: Throwable {
	public construct(message String = '', code Int = 0, previous Throwable? = none)
}
extern class Error: Throwable {
	public construct(message String = '', code Int = 0, previous Throwable? = none)
}
extern class ErrorException: Exception {}
extern class AssertionError: Error {}
extern class TypeError: Error {}
extern class ValueError: Error {}
extern class LogicException: Exception {}
extern class RuntimeException: Exception {}

