extern func array_reverse(array) Array
extern func array_map(callback (item Mixed) Mixed, items0 Array, items1 Array? = #default) Array
extern func array_filter(items Array, callback (item Mixed) Mixed = #default, mode Int = #default) Array
extern func array_reduce(items Array, callback (carry Mixed, item Mixed) Mixed, initial Mixed = #default) Mixed
